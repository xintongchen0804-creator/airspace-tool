    if(points.length)\{\
      if(airspaceLayer) map.removeLayer(airspaceLayer);\
      airspaceLayer = L.polygon(points, \{color:'#ff5c6c', weight:2\}).addTo(map);\
      tempPoints = points.map(p=>L.latLng(p[0],p[1]));\
      document.getElementById('airspaceSummary').innerHTML = `\uc0\u24050 \u23548 \u20837  $\{points.length\} \u20010 \u28857 \u65292 \u21487 \u23548 \u20986 KML\u12290 `;\
    \}\
  \};\
  // KML\uc0\u23548 \u20986 \
  function kmlEscape(str)\{ return str.replace(/&/g,'&amp;').replace(/</g,'&lt;'); \}\
  document.getElementById('exportKmlBtn').onclick = function()\{\
    if(!tempPoints.length && !airspaceLayer) \{ alert("\uc0\u27809 \u26377 \u36793 \u30028 \u28857 \u25968 \u25454 "); return; \}\
    let coords = tempPoints.map(p=>`$\{p.lng\},$\{p.lat\},0`).join(' ');\
    let name = document.getElementById('airspaceName').value || "\uc0\u39134 \u34892 \u31354 \u22495 ";\
    let kml = `<?xml version="1.0" encoding="UTF-8"?><kml xmlns="http://www.opengis.net/kml/2.2"><Placemark><name>$\{kmlEscape(name)\}</name><Polygon><outerBoundaryIs><LinearRing><coordinates>$\{coords\}</coordinates></LinearRing></outerBoundaryIs></Polygon></Placemark></kml>`;\
    let blob = new Blob([kml], \{type:"application/vnd.google-earth.kml+xml"\});\
