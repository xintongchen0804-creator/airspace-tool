  \};\
  document.getElementById('exportAirspaceCsvBtn').onclick = function()\{\
    if(!tempPoints.length) return;\
    let csv = "\uc0\u32463 \u24230 ,\u32428 \u24230 \\n"+tempPoints.map(p=>`$\{p.lng\},$\{p.lat\}`).join("\\n");\
    let blob = new Blob([csv], \{type:"text/csv"\}); let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download="airspace_points.csv"; a.click();\
  \};\
  document.getElementById('judgeBtn').onclick = function()\{\
    let lng = parseFloat(document.getElementById('lng').value), lat = parseFloat(document.getElementById('lat').value);\
    if(isNaN(lng)||isNaN(lat)) alert("\uc0\u35831 \u36755 \u20837 \u26377 \u25928 \u32463 \u32428 \u24230 ");\
    else \{ map.setView([lat,lng], 12); if(currentMarker) map.removeLayer(currentMarker); currentMarker = L.marker([lat,lng]).addTo(map); performJudgment(lat,lng); \}\
  \};\
  document.getElementById('placeBtn').onclick = searchPlace;\
  document.getElementById('copyCoordBtn').onclick = copyCoord;\
  document.getElementById('clearBtn').onclick = function()\{ if(currentMarker) map.removeLayer(currentMarker); document.getElementById('lng').value="113"; document.getElementById('lat').value="23"; \};\
  document.getElementById('zoomIn').onclick = ()=>map.zoomIn();\
  document.getElementById('zoomOut').onclick = ()=>map.zoomOut();\
  document.getElementById('resetView').onclick = ()=>map.setView([23.13,113.3],9);\
  document.getElementById('airspaceCategory').onchange = function()\{\
    let lat=parseFloat(document.getElementById('lat').value), lng=parseFloat(document.getElementById('lng').value);\
    if(!isNaN(lat)&&!isNaN(lng)) performJudgment(lat,lng);\
  \};\
  // \uc0\u25209 \u37327 \u21028 \u26029 \u31616 \u21270 \
  document.getElementById('bulkBtn').onclick = function()\{\
    let text = document.getElementById('bulk').value;\
    let lines = text.split(/\\r?\\n/); let results=[];\
    for(let line of lines)\{\
      let parts = line.split(','); let lng, lat, name="";\
      if(parts.length>=2)\{ lng=parseFloat(parts[parts.length-2]); lat=parseFloat(parts[parts.length-1]); name=parts.slice(0,-2).join(',') || "\uc0\u28857 "; \}\
      if(isNaN(lng)||isNaN(lat)) continue;\
      let inside=false;\
      for(let i=0;i<RECTS.length;i+=4)\{ let x1=RECTS[i]/1e6,y1=RECTS[i+1]/1e6,x2=RECTS[i+2]/1e6,y2=RECTS[i+3]/1e6; if(lng>=x1&&lng<=x2&&lat>=y1&&lat<=y2)\{ inside=true; break; \} \}\
      results.push(\{name, lng, lat, inside\});\
    \}\
    let html='<table><tr><th>\uc0\u21517 \u31216 </th><th>\u32463 \u24230 </th><th>\u32428 \u24230 </th><th>\u36866 \u39134 \u29366 \u24577 </th></tr>';\
    for(let r of results) html+=`<tr><td>$\{r.name\}</td><td>$\{r.lng\}</td><td>$\{r.lat\}</td><td>$\{r.inside?'<span style="color:#2dd477">\uc0\u22312 \u36866 \u39134 \u21306 </span>':'<span style="color:#ff5c6c">\u19981 \u22312 \u36866 \u39134 \u21306 </span>'\}</td></tr>`;\
    html+='</table>';\
    let div=document.getElementById('bulkTable'); div.style.display='block'; div.innerHTML=html;\
  \};\
  document.getElementById('downloadBtn').onclick = function()\{\
    let text = document.getElementById('bulk').value, lines = text.split(/\\r?\\n/);\
    let csvRows=["\uc0\u21517 \u31216 ,\u32463 \u24230 ,\u32428 \u24230 ,\u29366 \u24577 "];\
    for(let line of lines)\{\
      let parts = line.split(','); let lng, lat, name="";\
      if(parts.length>=2)\{ lng=parseFloat(parts[parts.length-2]); lat=parseFloat(parts[parts.length-1]); name=parts.slice(0,-2).join(',') || "\uc0\u28857 "; \}\
      if(isNaN(lng)||isNaN(lat)) continue;\
      let inside=false;\
      for(let i=0;i<RECTS.length;i+=4)\{ let x1=RECTS[i]/1e6,y1=RECTS[i+1]/1e6,x2=RECTS[i+2]/1e6,y2=RECTS[i+3]/1e6; if(lng>=x1&&lng<=x2&&lat>=y1&&lat<=y2)\{ inside=true; break; \} \}\
      csvRows.push(`"$\{name\}",$\{lng\},$\{lat\},$\{inside?"\uc0\u22312 \u36866 \u39134 \u21306 ":"\u19981 \u22312 \u36866 \u39134 \u21306 "\}`);\
    \}\
    let blob = new Blob(["\\uFEFF"+csvRows.join("\\n")], \{type:"text/csv;charset=utf-8;"\});\
    let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download="bulk_result.csv"; a.click();\
  \};\
  // \uc0\u20999 \u25442 \u22478 \u24066 /\u22320 \u26631 \u26174 \u31034  (\u31616 \u21270 )\
  document.getElementById('toggleCities').addEventListener('change', (e)=>\{\});\
  document.getElementById('toggleLandmarks').addEventListener('change', (e)=>\{\});\
  initMap();\
\})();\
</script>\
