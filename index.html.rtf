      loadGridPolygons();\
    \} else \{\
      console.warn("\uc0\u32593 \u26684 \u25968 \u25454 \u26410 \u21152 \u36733 \u65292 \u20294 \u24037 \u20855 \u20854 \u20182 \u21151 \u33021 \u27491 \u24120 ");\
      document.getElementById('count').innerText = '0';\
    \}\
    map.on('click', onMapClick);\
    map.on('mousemove', function(e) \{\
      document.getElementById('coordInfo').innerHTML = `\uc0\u32463 \u24230 : $\{e.latlng.lng.toFixed(6)\} , \u32428 \u24230 : $\{e.latlng.lat.toFixed(6)\}`;\
    \});\
    // \uc0\u32553 \u25918 \u25552 \u31034 \
    map.on('zoomend', function() \{ currentZoom = map.getZoom(); \});\
  \}\
  \
  function loadGridPolygons() \{\
    if (!STATS || !RECTS) return;\
    document.getElementById('count').innerText = STATS.count || RECTS.length/4;\
    for(let i=0; i<RECTS.length; i+=4) \{\
      let x1 = RECTS[i]/1000000, y1 = RECTS[i+1]/1000000, x2 = RECTS[i+2]/1000000, y2 = RECTS[i+3]/1000000;\
      let bounds = [[y1,x1],[y2,x2]];\
