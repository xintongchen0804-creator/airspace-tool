        let str = tempPoints.map(p=>`$\{p.lat.toFixed(5)\},$\{p.lng.toFixed(5)\}`).join(';');\
        document.getElementById('airspaceSummary').innerHTML = `\uc0\u24050 \u35760 \u24405  $\{tempPoints.length\} \u20010 \u36793 \u30028 \u28857 \u65292 \u21487 \u23548 \u20986 KML\u12290 `;\
      \} else alert("\uc0\u33267 \u23569 \u38656 \u35201 3\u20010 \u28857 ");\
      if(polylineTemp) map.removeLayer(polylineTemp);\
    \}\
  \};\
  map.on('click', function(e)\{\
    if(!drawMode) return;\
    tempPoints.push(e.latlng);\
    if(polylineTemp) polylineTemp.setLatLngs(tempPoints);\
  \});\
  document.getElementById('undoAirspaceBtn').onclick = ()=>\{\
    if(drawMode && tempPoints.length) \{ tempPoints.pop(); if(polylineTemp) polylineTemp.setLatLngs(tempPoints); \}\
  \};\
  document.getElementById('clearAirspaceBtn').onclick = ()=>\{\
    if(airspaceLayer) map.removeLayer(airspaceLayer);\
    tempPoints=[]; if(polylineTemp) polylineTemp.setLatLngs([]);\
    document.getElementById('airspaceSummary').innerHTML = "\uc0\u36793 \u30028 \u24050 \u28165 \u31354 ";\
  \};\
  // \uc0\u23548 \u20837 \u22352 \u26631 \
  document.getElementById('importAirspaceBtn').onclick = function()\{\
    let raw = document.getElementById('airspaceCoords').value;\
    let lines = raw.split(/\\r?\\n/);\
    let points=[], src = document.getElementById('coordSource').value;\
    for(let line of lines)\{\
      let m = line.match(/([\\-\\d\\.]+)\\s*,\\s*([\\-\\d\\.]+)/);\
      if(m)\{\
        let lng=parseFloat(m[1]), lat=parseFloat(m[2]);\
        if(src==='gcj02') \{ let delta = 0.0065; lng-=delta; lat-=delta; \} // \uc0\u31616 \u21333 \u20559 \u31227 \u31034 \u24847 \u65292 \u23454 \u38469 \u31934 \u30830 \u36716 \u25442 \u38656 \u35201 \u24211 \u65292 \u27492 \u22788 \u20165 \u31034 \u24847 \
        else if(src==='bd09') \{ lng-=0.012; lat-=0.004; \}\
