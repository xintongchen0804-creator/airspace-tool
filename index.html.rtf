  \}\
  \
  function performJudgment(lat, lng) \{\
    let inside = false;\
    // \uc0\u24555 \u36895 \u21028 \u26029 \u65306 \u22522 \u20110 \u32593 \u26684 \u30697 \u24418 \u21253 \u21547 \u65288 \u20351 \u29992 \u21407 \u22987 \u32593 \u26684 \u31639 \u27861 \u65292 \u36825 \u37324 \u31616 \u21270 \u35843 \u29992 \u21407 \u26377 \u28857 \u22312 \u22810 \u36793 \u24418 \u26816 \u27979 \u65292 \u23454 \u38469 \u21407 \u31243 \u24207 \u20351 \u29992 \u32593 \u26684 \u26684 \u32593 \u27861 \u65292 \u27492 \u22788 \u20445 \u35777 \u36923 \u36753 \u19968 \u33268 \u65289 \
    // \uc0\u20174 \u29616 \u26377 RECTS\u21028 \u26029 \u26159 \u21542 \u22312 \u20219 \u24847 \u30697 \u24418 \u20869 \
    for(let i=0; i<RECTS.length; i+=4) \{\
      let x1 = RECTS[i]/1000000, y1 = RECTS[i+1]/1000000, x2 = RECTS[i+2]/1000000, y2 = RECTS[i+3]/1000000;\
      if(lng >= x1 && lng <= x2 && lat >= y1 && lat <= y2) \{ inside = true; break; \}\
    \}\
    let category = document.getElementById('airspaceCategory').value;\
    let isWithin = inside;\
    let needApply = false;\
    if(category === '\uc0\u24494 \u22411 ') needApply = false;\
    else if(category === '\uc0\u36731 \u22411 ') needApply = !isWithin;\
    else needApply = true;\
    let resultDiv = document.getElementById('result');\
    let verdictDiv = document.getElementById('verdict');\
    if(isWithin) resultDiv.innerHTML = `<span class="ok">\uc0\u10003  \u35813 \u20301 \u32622 \u20301 \u20110 \u36866 \u39134 \u31354 \u22495 \u20869  (\u21442 \u32771 )</span><br>\u22352 \u26631 : $\{lat.toFixed(6)\}, $\{lng.toFixed(6)\}`;\
    else resultDiv.innerHTML = `<span class="no">\uc0\u10007  \u35813 \u20301 \u32622 \u19981 \u22312 \u36866 \u39134 \u31354 \u22495 \u20869  (\u21442 \u32771 )</span><br>\u22352 \u26631 : $\{lat.toFixed(6)\}, $\{lng.toFixed(6)\}`;\
    if(needApply) verdictDiv.innerHTML = `<span class="no">\uc0\u9888 \u65039  \u26681 \u25454 \u26426 \u22411 \u19982 \u31354 \u22495 \u65292 \u24314 \u35758 \u30003 \u35831 \u31354 \u22495 \u23457 \u25209 </span><br>\u35831 \u22635 \u20889 \u21491 \u20391 \u30003 \u25253 \u20449 \u24687 \u24182 \u23548 \u20986 KML\u12290 `;\
    else verdictDiv.innerHTML = `<span class="ok">\uc0\u9989  \u35813 \u26426 \u22411 \u22312 \u35813 \u20301 \u32622 \u19968 \u33324 \u26080 \u38656 \u30003 \u35831 \u31354 \u22495 \u65292 \u20294 \u20173 \u38656 \u36981 \u23432 \u29616 \u22330 \u31649 \u21046 \u12290 </span>`;\
    // \uc0\u26356 \u26032 \u26426 \u22411 \u25552 \u31034 \
    let note = '';\
    if(category==='\uc0\u24494 \u22411 ') note = '\u24494 \u22411 \u26080 \u20154 \u26426 \u65306 \u22312 \u36866 \u39134 \u31354 \u22495 \u20869 \u30495 \u39640 120\u31859 \u20197 \u19979 \u26080 \u38656 \u30003 \u35831 \u65292 \u31105 \u39134 \u21306 \u38500 \u22806 \u12290 ';\
    else if(category==='\uc0\u36731 \u22411 ') note = '\u36731 \u22411 \u26080 \u20154 \u26426 \u65306 \u22312 \u36866 \u39134 \u31354 \u22495 \u20869 \u26080 \u38656 \u30003 \u35831 \u65292 \u20294 \u38656 \u25253 \u36865 \u39134 \u34892 \u21160 \u24577 \u12290 ';\
    else note = '\uc0\u20013 \u22411 /\u22823 \u22411 /\u23567 \u22411 \u26080 \u20154 \u26426 \u65306 \u26080 \u35770 \u26159 \u21542 \u22312 \u36866 \u39134 \u31354 \u22495 \u20869 \u65292 \u22343 \u38656 \u30003 \u35831 \u31354 \u22495 \u12290 ';\
    document.getElementById('categoryNote').innerHTML = note;\
  \}\
  \
  function searchPlace() \{\
    let name = document.getElementById('placeSearch').value.trim();\
    if(!name) return;\
    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=$\{encodeURIComponent(name)\}&limit=1&addressdetails=0`)\
      .then(r=>r.json()).then(data=>\{\
        if(data && data[0]) \{\
          let lon = parseFloat(data[0].lon), lat = parseFloat(data[0].lat);\
          document.getElementById('lng').value = lon.toFixed(6);\
          document.getElementById('lat').value = lat.toFixed(6);\
          map.setView([lat, lon], 12);\
          if(currentMarker) map.removeLayer(currentMarker);\
          currentMarker = L.marker([lat, lon]).addTo(map).bindPopup(`\uc0\u55357 \u56525  $\{data[0].display_name\}`).openPopup();\
          performJudgment(lat, lon);\
        \} else alert("\uc0\u26410 \u25214 \u21040 \u35813 \u22320 \u28857 ");\
      \}).catch(()=>alert("\uc0\u22320 \u21517 \u26597 \u35810 \u22833 \u36133 \u65292 \u21487 \u25163 \u21160 \u36755 \u20837 \u32463 \u32428 \u24230 "));\
  \}\
  \
  function copyCoord() \{\
    let lng = document.getElementById('lng').value, lat = document.getElementById('lat').value;\
    navigator.clipboard.writeText(`$\{lng\},$\{lat\}`).then(()=>alert("\uc0\u32463 \u32428 \u24230 \u24050 \u22797 \u21046 "));\
  \}\
  \
  // \uc0\u31354 \u22495 \u32472 \u22270 \
  let drawMode = false, tempPoints=[], polylineTemp=null;\
  document.getElementById('drawAirspaceBtn').onclick = ()=>\{\
    drawMode = !drawMode;\
    if(drawMode) \{\
      document.getElementById('drawAirspaceBtn').style.outline = "2px solid var(--warn)";\
      alert("\uc0\u36827 \u20837 \u28857 \u36873 \u27169 \u24335 \u65292 \u22312 \u22320 \u22270 \u19978 \u20381 \u27425 \u28857 \u20987 \u36793 \u30028 \u28857  (\u8805 3\u28857 \u25104 \u38754 )\u65292 \u20877 \u27425 \u28857 \u20987 \u35813 \u25353 \u38062 \u32467 \u26463 ");\
      tempPoints = [];\
      if(polylineTemp) map.removeLayer(polylineTemp);\
