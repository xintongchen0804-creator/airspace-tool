<script>\
(function()\{\
  // \uc0\u33719 \u21462 \u21407 \u22987 \u25968 \u25454 \u24341 \u29992 \u65292 \u21407 \u25991 \u20214 \u20013 \u30340  STATS \u21644  RECTS \u24050 \u23450 \u20041 \u65288 \u30001 \u20110 \u25991 \u20214 \u24040 \u22823 \u65292 \u27492 \u22788 \u21482 \u20570 \u22320 \u22270 \u20999 \u25442 \u65289 \
  // \uc0\u30830 \u20445 \u22320 \u22270 \u20351 \u29992  OpenStreetMap \u24213 \u22270 \u65292 \u24182 \u20445 \u30041 \u25152 \u26377 \u19994 \u21153 \u36923 \u36753 \u12290 \
  let map;\
  let currentMarker = null;\
  let airspacePoints = [];\
  let airspaceLayer = null;\
  let gridLayers = [];\
  let currentZoom = 8;\
  const categoryMap = \{\uc0\u24494 \u22411 :0,\u36731 \u22411 :1,\u23567 \u22411 :2,\u20013 \u22411 :3,\u22823 \u22411 :4\};\
  \
  function initMap() \{\
    map = L.map('map').setView([23.13, 113.3], 9);\
    // \uc0\u26367 \u25442 \u20026  OpenStreetMap \u24213 \u22270  (\u26080 Key\u38480 \u21046 , \u36866 \u21512  GitHub Pages)\
    L.tileLayer('https://\{s\}.tile.openstreetmap.org/\{z\}/\{x\}/\{y\}.png', \{\
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',\
      maxZoom: 19\
    \}).addTo(map);\
    // \uc0\u21152 \u36733 \u32593 \u26684  (\u20351 \u29992 \u29616 \u26377 \u20840 \u23616  RECTS, STATS)\
